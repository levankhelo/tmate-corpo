#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"
export TMATE_CORPO_LOCAL_CONFIG="${TMATE_CORPO_LOCAL_CONFIG:-$REPO_ROOT/.tmate-corpo.env}"
# shellcheck source=../lib/common.sh
source "$REPO_ROOT/lib/common.sh"

INSTALLED_SERVICE="$INSTALL_ROOT/bin/tmate-corpo-service"

usage() {
  cat <<EOF
Usage:
  make config
  USER_MAC=user@user-mac.local make install
  make start
  make stop
  make restart
  make status
  make doctor
  make logs
  make uninstall

Environment:
  USER_MAC                    USER Mac SSH target that receives the connector.
  USER_COMMAND_PATH           Command path created on USER Mac. Default: ~/bin/tmate-corpo
  CORPO_SSH_PORT              CORPO user-space sshd port. Default: 2222
  USER_REVERSE_PORT           USER localhost port exposed by reverse tunnel. Default: 2223
  SKIP_SSH_COPY_ID            Do not try ssh-copy-id during install. Default: 0

Examples:
  make config
  make install
  USER_MAC=alex@mac-mini.local make install
  USER_MAC=alex@mac-mini.local USER_COMMAND_PATH='~/bin/tmate-corpo' make install
EOF
}

prompt_default() {
  local prompt="$1"
  local default_value="$2"
  local value

  if [[ -n "$default_value" ]]; then
    read -r -p "$prompt [$default_value]: " value
    printf '%s\n' "${value:-$default_value}"
  else
    read -r -p "$prompt: " value
    printf '%s\n' "$value"
  fi
}

prompt_yes_no() {
  local prompt="$1"
  local default_value="$2"
  local value
  local suffix="[y/N]"

  [[ "$default_value" == "1" ]] && suffix="[Y/n]"

  while true; do
    read -r -p "$prompt $suffix: " value
    value="${value:-$([[ "$default_value" == "1" ]] && printf 'y' || printf 'n')}"

    case "$value" in
      y|Y|yes|YES)
        printf '1\n'
        return 0
        ;;
      n|N|no|NO)
        printf '0\n'
        return 0
        ;;
      *)
        printf 'Please answer y or n.\n' >&2
        ;;
    esac
  done
}

check_config_access() {
  local ssh_ok=0
  local path_ok=0

  printf '\nChecking SSH access from CORPO Mac to USER Mac %s...\n' "$FILE_TARGET_MAC"

  if ssh -o BatchMode=yes -o ConnectTimeout=8 "$FILE_TARGET_MAC" true >/dev/null 2>&1; then
    printf 'OK: SSH key login works.\n'
    ssh_ok=1
  else
    printf 'Issue: CORPO Mac cannot SSH into USER Mac with key login: %s.\n' "$FILE_TARGET_MAC"
    printf 'Suggested steps:\n'
    printf '  1. On USER Mac, enable Remote Login: System Settings -> General -> Sharing -> Remote Login\n'
    printf '  2. Run: ssh-copy-id %s\n' "$FILE_TARGET_MAC"
    printf '  3. Test: ssh %s true\n' "$FILE_TARGET_MAC"

    if have ssh-copy-id && [[ "$(prompt_yes_no "Run ssh-copy-id now?" "0")" == "1" ]]; then
      ssh-copy-id "$FILE_TARGET_MAC"
      if ssh -o BatchMode=yes -o ConnectTimeout=8 "$FILE_TARGET_MAC" true >/dev/null 2>&1; then
        printf 'OK: SSH key login works now.\n'
        ssh_ok=1
      fi
    fi
  fi

  if (( ssh_ok == 1 )); then
    printf '\nChecking USER Mac command path %s...\n' "$FILE_TARGET_PATH"
    if target_path_ready_quiet; then
      printf 'OK: USER Mac command path is writable.\n'
      path_ok=1
    else
      printf 'Issue: cannot write %s on %s.\n' "$FILE_TARGET_PATH" "$FILE_TARGET_MAC"
      printf 'Suggested steps:\n'
      printf '  1. Use the USER home path: USER_COMMAND_PATH='\''~/bin/tmate-corpo'\'' make config\n'
      printf '  2. Re-run: make doctor\n'
      printf '  3. If ~/bin is not on PATH on USER Mac, add it there after install.\n'
    fi
  fi

  printf '\nSaved config files:\n'
  printf '  %s\n' "$LOCAL_CONFIG_FILE"
  printf '  %s\n' "$CONFIG_FILE"

  if (( ssh_ok == 1 && path_ok == 1 )); then
    printf '\nConfig looks ready. Run: make install\n'
  else
    printf '\nConfig was saved, but fix the issues above before running make install.\n'
  fi
}

configure() {
  load_config

  printf 'tmate-corpo configuration\n\n'

  USER_MAC="$(prompt_default "USER Mac SSH address, for example user@mac-mini.local" "${USER_MAC:-${FILE_TARGET_MAC:-}}")"
  [[ -n "$USER_MAC" ]] || die "USER Mac SSH address is required"
  FILE_TARGET_MAC="$USER_MAC"

  USER_COMMAND_PATH="$(prompt_default "Command path to create on USER Mac" "${USER_COMMAND_PATH:-$FILE_TARGET_PATH}")"
  FILE_TARGET_PATH="$USER_COMMAND_PATH"
  CORPO_SSH_PORT="$(prompt_default "CORPO user-space sshd port" "$CORPO_SSH_PORT")"
  USER_REVERSE_PORT="$(prompt_default "USER localhost reverse-tunnel port" "$USER_REVERSE_PORT")"
  REMOTE_INSTALL_WITH_SUDO=0
  SKIP_SSH_COPY_ID="$(prompt_yes_no "Skip ssh-copy-id attempts during install?" "$SKIP_SSH_COPY_ID")"

  require_sshd

  write_local_config
  write_config
  check_config_access
}

write_plist() {
  mkdir -p "$(dirname "$PLIST_FILE")" "$LOG_DIR"
  cat >"$PLIST_FILE" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>$INSTALLED_SERVICE</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>$INSTALL_ROOT</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>TMATE_CORPO_HOME</key>
    <string>$INSTALL_ROOT</string>
  </dict>
  <key>StandardOutPath</key>
  <string>$STDOUT_LOG</string>
  <key>StandardErrorPath</key>
  <string>$STDERR_LOG</string>
</dict>
</plist>
EOF
}

launchctl_bootout() {
  launchctl bootout "$(launch_domain)" "$PLIST_FILE" >/dev/null 2>&1 || true
}

launchctl_bootstrap() {
  local domain
  domain="$(launch_domain)"

  launchctl_bootout
  launchctl bootstrap "$domain" "$PLIST_FILE"
  launchctl enable "$domain/$LABEL" >/dev/null 2>&1 || true
  launchctl kickstart -k "$domain/$LABEL" >/dev/null 2>&1 || true
}

publish_current_connector() {
  local connect_command

  prepare_userspace_sshd
  start_reverse_tunnel
  connect_command="$(corpo_ssh_command)"
  publish_connector "$connect_command"
}

install_files() {
  mkdir -p "$INSTALL_ROOT/bin" "$INSTALL_ROOT/lib" "$LOG_DIR"
  install -m 0755 "$REPO_ROOT/bin/tmate-corpo-service" "$INSTALLED_SERVICE"
  install -m 0644 "$REPO_ROOT/lib/common.sh" "$INSTALL_ROOT/lib/common.sh"
}

install_service() {
  require_macos
  require_sshd
  require_target

  install_files
  write_config
  write_plist
  ensure_ssh_login
  preflight_target_path
  publish_current_connector
  launchctl_bootstrap

  log "installed and started $LABEL"
  log "USER Mac command was written to $FILE_TARGET_MAC:$FILE_TARGET_PATH"
}

uninstall_service() {
  require_macos
  launchctl_bootout
  stop_reverse_tunnel
  stop_userspace_sshd
  rm -f "$PLIST_FILE"
  log "uninstalled $LABEL"
}

start_service() {
  require_macos
  [[ -f "$PLIST_FILE" ]] || die "service is not installed; run: USER_MAC=user@user-mac.local make install"
  launchctl_bootstrap
  log "started $LABEL"
}

stop_service() {
  require_macos
  launchctl_bootout
  stop_reverse_tunnel
  stop_userspace_sshd
  log "stopped $LABEL"
}

service_status() {
  require_macos
  load_config

  if launchctl print "$(launch_domain)/$LABEL" >/dev/null 2>&1; then
    printf 'launchd: running\n'
  else
    printf 'launchd: stopped\n'
  fi

  if sshd_alive; then
    printf 'userspace sshd: running\n'
    printf 'connect: %s\n' "$(corpo_ssh_command)"
  else
    printf 'userspace sshd: stopped\n'
  fi

  if reverse_tunnel_alive; then
    printf 'reverse tunnel: running\n'
  else
    printf 'reverse tunnel: stopped\n'
  fi

  printf 'USER Mac command: %s:%s\n' "${FILE_TARGET_MAC:-unset}" "$FILE_TARGET_PATH"
  printf 'logs: %s %s\n' "$STDOUT_LOG" "$STDERR_LOG"
}

show_logs() {
  mkdir -p "$LOG_DIR"
  touch "$STDOUT_LOG" "$STDERR_LOG"
  tail -n 80 -f "$STDOUT_LOG" "$STDERR_LOG"
}

doctor() {
  load_config

  printf 'Loaded config:\n'
  printf '  local config: %s\n' "${LOCAL_CONFIG_FILE:-unset}"
  printf '  runtime config: %s\n' "$CONFIG_FILE"
  printf '  USER_MAC: %s\n' "${FILE_TARGET_MAC:-unset}"
  printf '  USER_COMMAND_PATH: %s\n' "$FILE_TARGET_PATH"
  printf '  CORPO_SSH_PORT: %s\n' "$CORPO_SSH_PORT"
  printf '  USER_REVERSE_PORT: %s\n' "$USER_REVERSE_PORT"
  printf '  REMOTE_INSTALL_WITH_SUDO: 0 (forced; sudo install is disabled)\n'
  printf '  SKIP_SSH_COPY_ID: %s\n' "$SKIP_SSH_COPY_ID"
  printf '  SSHD_BIN: %s\n' "$SSHD_BIN"
  printf '\n'

  require_target

  printf 'Checking SSH key login...\n'
  ssh -o BatchMode=yes -o ConnectTimeout=8 "$FILE_TARGET_MAC" true
  printf 'OK: SSH key login works.\n\n'

  printf 'Checking USER Mac command path with create mode...\n'
  remote_check_user_command_path create
  printf 'OK: USER Mac command path is writable.\n\n'

  printf 'Checking whether USER Mac command currently exists...\n'
  if remote_user_command_exists; then
    printf 'OK: USER Mac command exists.\n'
  else
    printf 'Missing: USER Mac command has not been published yet. Run: make install or make once\n'
  fi
  remote_user_command_info

  printf '\nChecking USER Mac PATH setup...\n'
  remote_ensure_user_command_path_on_path

  printf '\nChecking USER reverse tunnel port...\n'
  ssh -o BatchMode=yes -o ConnectTimeout=8 "$FILE_TARGET_MAC" /bin/bash -s -- "$USER_REVERSE_PORT" <<'REMOTE'
set -euo pipefail
port="$1"
if nc -z 127.0.0.1 "$port" >/dev/null 2>&1; then
  printf 'OK: USER localhost port %s is listening.\n' "$port"
else
  printf 'Missing: USER localhost port %s is not listening. Run: make install or make restart\n' "$port"
fi
REMOTE
}

publish_once() {
  local connect_command

  load_config
  require_sshd
  require_target
  publish_current_connector
}

main() {
  local command="${1:-help}"

  case "$command" in
    install)
      load_config
      install_service
      ;;
    config)
      configure
      ;;
    uninstall)
      load_config
      uninstall_service
      ;;
    start)
      load_config
      start_service
      ;;
    stop)
      load_config
      stop_service
      ;;
    restart)
      load_config
      stop_service
      start_service
      ;;
    status)
      service_status
      ;;
    doctor)
      doctor
      ;;
    logs)
      show_logs
      ;;
    once)
      publish_once
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
