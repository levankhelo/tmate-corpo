#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"

load_config
require_sshd
require_target
prepare_userspace_sshd

connect_command="$(corpo_ssh_command)"
publish_connector "$connect_command"
start_reverse_tunnel

log "starting user-space sshd on 127.0.0.1:$CORPO_SSH_PORT"
exec "$SSHD_BIN" -D -f "$SSHD_CONFIG" -E "$SSHD_LOG"
