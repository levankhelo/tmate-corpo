# Copy to .tmate-corpo.env or run: make config
#
# Run this project on the CORPO Mac.
# USER_MAC is the SSH target for the user's Mac. The CORPO Mac writes the
# tmate-corpo command there whenever the CORPO tmate session changes.
USER_MAC=user@user-mac.local

# The executable path created on the USER Mac.
USER_COMMAND_PATH='/usr/local/bin/tmate-corpo'

# /usr/local/bin usually requires passwordless sudo on the USER Mac.
REMOTE_INSTALL_WITH_SUDO=1

# Set to 1 if you want install to skip ssh-copy-id.
SKIP_SSH_COPY_ID=0

# Optional advanced settings.
TMATE_REFRESH_SECONDS=10
TMATE_EMPTY_GRACE_SECONDS=5
TMATE_RESTART_ON_DISCONNECT=1
