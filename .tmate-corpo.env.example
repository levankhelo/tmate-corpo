# Copy to .tmate-corpo.env or run: make config
#
# Run this project on the CORPO Mac.
# USER_MAC is the SSH target for the user's Mac. The CORPO Mac writes the
# tmate-corpo command there whenever CORPO connection settings change.
USER_MAC=user@user-mac.local

# The executable path created on the USER Mac.
USER_COMMAND_PATH='~/bin/tmate-corpo'

# CORPO runs a user-space sshd locally on this port. Pick an unused high port.
CORPO_SSH_PORT=2222

# USER gets this port via the reverse SSH tunnel.
USER_REVERSE_PORT=2223

# USER reverse tunnel bind host. auto detects the USER Mac LAN IP.
# Use 127.0.0.1 only if USER sshd does not allow LAN reverse binds.
USER_REVERSE_BIND_HOST=auto

# Host written into ~/bin/tmate-corpo on the USER Mac. auto detects USER LAN IP.
USER_CONNECT_HOST=auto

# Sudo install is disabled; the USER command is written under the USER home.
REMOTE_INSTALL_WITH_SUDO=0

# Set to 1 if you want install to skip ssh-copy-id.
SKIP_SSH_COPY_ID=0
